*.swp
*.swo
*~

# Environment & secrets
.env
.streamlit/secrets.toml

# Data — large pipeline artifacts not needed to run the app
data/raw/pdfs/       # 6.8 GB — rebuilt by download_pdfs.py
data/raw/csvs/       # 78 MB  — rebuilt by download_csvs.py
data/processed/      # 700 MB — rebuilt by run_extraction.py + run_indexing.py

# Sentence transformer weights — large; use HuggingFace Hub instead
models/sentence_transformer/
# Only exclude binary weight files; .joblib classifiers ARE committed
models/sentiment_classifier/*.pt
models/sentiment_classifier/*.bin

# Vector store — rebuild from embeddings
vectorstore/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Learning materials — not part of the project
DOCS/

# Misc
*.log
*.tmp

# Claude
.claude
Claude.md
