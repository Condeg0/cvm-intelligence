*~

# Environment & secrets
.env
.streamlit/secrets.toml

# Data — large pipeline artifacts (6.8 GB PDFs, 78 MB CSVs, 700 MB processed files)
# Rebuilt locally via: download_pdfs.py / download_csvs.py / run_extraction.py
data/raw/pdfs/
data/raw/csvs/
data/processed/

# Full SQLite database (271 MB) — contains chunks table with 97k text blobs.
# Only the slim dashboard DB (432 KB, no chunks) is committed to git.
data/cvm_metrics.db

# Sentence transformer weights — download from HuggingFace Hub at runtime
models/sentence_transformer/

# Only exclude binary weight files; .joblib classifiers ARE committed
models/sentiment_classifier/*.pt
models/sentiment_classifier/*.bin

# Vector store — rebuild from embeddings via run_indexing.py
vectorstore/
# BM25 index pickle — rebuild via run_indexing.py
*.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Learning materials — not part of the project
DOCS/

# Misc
*.log
*.tmp

# Claude / AI assistant files — personal use only, not for the public repo
.claude/
CLAUDE.md
**/CLAUDE.md
claude_settings.json
gitignore.txt

